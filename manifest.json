{
    "manifest_version": 3,
    "name": "KeyMaker",
    "version": "1.0",
    "action": {
        "default_popup": "index.html",
        "default_icon": {
            "16": "icons/16.png",
            "32": "icons/32.png",
            "48": "icons/48.png"
        }
    },
    "icons": {
        "16": "icons/16.png",
        "32": "icons/32.png",
        "48": "icons/48.png",
        "128": "icons/128.png"
    },
    "host_permissions": [
        "http://127.0.0.1:5501/"
    ],
    "permissions": [
        "tabs",
        "activeTab"
    ],
    "default_locale": "en"
}